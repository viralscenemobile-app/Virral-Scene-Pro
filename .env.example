# --- AI & GENERATION ---
# GEMINI_API_KEY: Required for Gemini AI API calls (moderation, enhancement).
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# API_KEY: Paid Gemini API key for Veo video generation.
# AI Studio provides this via the key selection dialog.
API_KEY=

# FAL_KEY: Required for fal.ai API calls (Kling, Flux, etc.).
FAL_KEY=

# --- CONVEX (DATABASE & REALTIME) ---
# VITE_CONVEX_URL: The URL of your Convex deployment.
VITE_CONVEX_URL=

# --- CLOUDFLARE R2 (STORAGE) ---
# VITE_R2_ACCOUNT_ID: Your Cloudflare Account ID.
VITE_R2_ACCOUNT_ID=

# VITE_R2_ACCESS_KEY_ID: R2 API Access Key.
VITE_R2_ACCESS_KEY_ID=

# VITE_R2_SECRET_ACCESS_KEY: R2 API Secret Key.
VITE_R2_SECRET_ACCESS_KEY=

# VITE_R2_BUCKET_NAME: The name of your R2 bucket.
VITE_R2_BUCKET_NAME=

# VITE_R2_PUBLIC_URL: The public URL of your R2 bucket (e.g., your custom domain or R2 dev URL).
VITE_R2_PUBLIC_URL=

# --- APP CONFIG ---
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=
