rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - firebaseUid: string (required, immutable)
    //   - username: string (required, unique-ish)
    //   - avatarUrl: string (required)
    //   - bio: string (optional)
    //   - followers: number (required)
    //   - following: number (required)
    //   - coins: number (required)
    //   - verified: boolean (required)
    //   - lastRewardClaimedAt: number (optional)
    //
    // Collection: creations
    // Document ID: creationId
    // Fields:
    //   - userId: string (required, immutable)
    //   - title: string (required)
    //   - prompt: string (required)
    //   - style: string (required)
    //   - videoUrl: string (required)
    //   - thumbnailUrl: string (required)
    //   - views: number (required)
    //   - likes: number (required)
    //   - comments: number (required)
    //   - isTemplate: boolean (required)
    //   - templateId: string (optional)
    //   - challengeId: string (optional)
    //   - createdAt: number (required, immutable)
    //
    // Collection: challenges
    // Document ID: challengeId
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - imageUrl: string (required)
    //   - prizePool: number (required)
    //   - entryFee: number (required)
    //   - endTime: number (required)
    //   - creatorId: string (required, immutable)
    //   - status: string (required, active/completed)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "viralscenemobile@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['firebaseUid', 'username', 'avatarUrl', 'followers', 'following', 'coins', 'verified', 'role']) &&
             data.firebaseUid is string &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 30 &&
             data.avatarUrl is string && isValidUrl(data.avatarUrl) &&
             data.followers is number && data.followers >= 0 &&
             data.following is number && data.following >= 0 &&
             data.coins is number && data.coins >= 0 &&
             data.verified is bool &&
             data.role in ['user', 'admin'];
    }

    function isValidCreation(data) {
      return hasRequiredFields(['userId', 'title', 'prompt', 'style', 'videoUrl', 'thumbnailUrl', 'views', 'likes', 'comments', 'isTemplate', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.prompt is string && data.prompt.size() > 0 && data.prompt.size() <= 1000 &&
             data.style is string &&
             data.videoUrl is string && isValidUrl(data.videoUrl) &&
             data.thumbnailUrl is string && isValidUrl(data.thumbnailUrl) &&
             data.views is number && data.views >= 0 &&
             data.likes is number && data.likes >= 0 &&
             data.comments is number && data.comments >= 0 &&
             data.isTemplate is bool &&
             data.createdAt is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.firebaseUid == resource.data.firebaseUid) || isAdmin();
    }

    // Creations collection
    match /creations/{creationId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidCreation(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() && isValidCreation(request.resource.data) && 
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.createdAt == resource.data.createdAt) || 
                       isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
